# Backend (from repo root: cd backend && go run ./cmd/server)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/game_designer?sslmode=disable
# HTTP_ADDR=:8080
# DEV=1
# AI_DRIVER=mock
# Real LLM + images (github.com/openai/openai-go):
# AI_DRIVER=openai
# AI_API_KEY=sk-...
# Optional proxy / Azure-style base URL:
# AI_BASE_URL=https://api.openai.com/v1
# AI_CHAT_MODEL=gpt-4o-mini
# AI_HTTP_TIMEOUT=90s
# Image generation (OpenAI images API; uses same key/base):
# AI_IMAGE_MODEL=dall-e-3
# AI_IMAGE_SIZE=1024x1024
# SESSION_TTL=720h

# Next.js: same as backend URL for rewrites; RSC also uses this for direct Go calls
# In web/.env.local:
# API_URL=http://127.0.0.1:8080
# Optional: show dev login button (needs DEV=1 on Go)
# NEXT_PUBLIC_DEV_LOGIN=1
#
# After migration 002, seed user can log in with:
#   email: indiedev@local.dev
#   password: password
# Or use /register for a new account.
