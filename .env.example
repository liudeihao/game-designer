# Backend (from repo root: cd backend && go run ./cmd/server)
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/game_designer?sslmode=disable
# HTTP_ADDR=:8080
# DEV=1
# AI_DRIVER=mock
# SESSION_TTL=720h

# Next.js: same as backend URL for rewrites; RSC also uses this for direct Go calls
# In web/.env.local:
# API_URL=http://127.0.0.1:8080
# Optional: show dev login button (needs DEV=1 on Go)
# NEXT_PUBLIC_DEV_LOGIN=1
